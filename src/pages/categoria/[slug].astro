---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductGrid from '../../components/sections/ProductGrid.astro';
import { supabase } from '../../lib/supabase';
import FilterPanel from "../../components/ui/FilterPanel.astro";
import type { Product } from '../../types/product';
import { Icon } from "astro-icon/components";

// SSR: Renderizado del lado del servidor (dinámico)
export const prerender = false;

const { slug } = Astro.params;

// Manejo especial para la página de ofertas
const isOffersPage = slug === 'ofertas';

let category = null;
let products = null;

if (isOffersPage) {
  // Para ofertas, no hay categoría, pero creamos un objeto simulado
  category = {
    id: 'ofertas',
    label: 'Ofertas',
    slug: 'ofertas',
    active: true
  };
  
  // Fetch productos con descuento
  const { data } = await supabase
    .from('products')
    .select(`
      *,
      product_categories (
        categories (
          id,
          label,
          slug
        )
      )
    `)
    .eq('active', true)
    .gt('discount_pct', 0) // Solo productos con descuento > 0
    .order('discount_pct', { ascending: false }); // Ordenar por mayor descuento primero
  
  products = data;
} else {
  // Fetch categoría normal
  const { data: categoryData } = await supabase
    .from('categories')
    .select('*')
    .eq('slug', slug)
    .eq('active', true)
    .single();

  if (!categoryData) {
    return Astro.redirect('/404');
  }
  
  category = categoryData;

  // Fetch productos de la categoría usando la tabla de unión
  const { data: productsData } = await supabase
    .from('products')
    .select(`
      *,
      product_categories!inner (
        category_id,
        categories (
          id,
          label,
          slug
        )
      )
    `)
    .eq('product_categories.category_id', category.id)
    .eq('active', true)
    .order('created_at', { ascending: false });
  
  products = productsData;
}

const mappedProducts: Product[] = (products || []).map(p => ({
  ...p,
  categories: p.product_categories?.map((pc: any) => pc.categories).filter(Boolean) || [],
  category_ids: p.product_categories?.map((pc: any) => pc.categories?.id).filter(Boolean) || [],
}));

// Descripciones SEO optimizadas por categoría
const categoryDescriptions: Record<string, { title: string; description: string; keywords: string }> = {
  'ofertas': {
    title: '🔥 Ofertas y Descuentos | Kuruba Sexshop - Hasta 30% OFF',
    description: '💰 ¡Aprovecha nuestras OFERTAS EXCLUSIVAS! Descuentos en juguetes, lubricantes y más. ¡Precios irresistibles! ⚡ Stock limitado. Compra ahora con envío discreto.',
    keywords: 'ofertas sexshop, descuentos productos eróticos, promociones juguetes sexuales'
  },
  'juguetes': {
    title: 'Juguetes Eróticos | Vibradores y Consoladores | Kuruba Sexshop',
    description: '✨ Amplia selección de juguetes eróticos: vibradores, consoladores, bullets, huevos vibradores y más. Para ella, para él y parejas. ¡Placer garantizado!',
    keywords: 'juguetes eróticos, vibradores, consoladores, juguetes sexuales, sex toys colombia'
  },
  'lubricantes': {
    title: 'Lubricantes Íntimos | Base Agua y Silicona | Kuruba Sexshop',
    description: '💧 Lubricantes de calidad premium: base agua, silicona, efecto calor y más. Compatibles con preservativos. ¡Máximo placer sin límites!',
    keywords: 'lubricantes íntimos, lubricantes sexuales, lubricante base agua, lubricante silicona'
  },
  // 'lenceria': {
  //   title: 'Lencería Sensual y Sexy | Conjuntos Eróticos | Kuruba Sexshop',
  //   description: '👙 Lencería sexy para conquistar: conjuntos, baby dolls, corsés, disfraces y más. Todas las tallas. ¡Siéntete irresistible!',
  //   keywords: 'lencería sensual, lencería sexy, ropa interior erótica, baby doll, corsés'
  // },
  // 'bondaje': {
  //   title: 'Bondaje y BDSM | Esposas, Cuerdas y Más | Kuruba Sexshop',
  //   description: '🔗 Explora el bondaje: esposas, vendas, látigos, cuerdas y accesorios BDSM. Para principiantes y expertos. ¡Atrévete a más!',
  //   keywords: 'bondaje, bdsm, esposas, látigos, juegos de dominación, accesorios bdsm'
  // },
  'masculino': {
    title: 'Productos Masculinos | Anillos, Masturbadores | Kuruba Sexshop',
    description: '💪 Productos diseñados para él: anillos vibradores, masturbadores, bombas, extensores y más. ¡Potencia tu placer!',
    keywords: 'productos masculinos, masturbadores, anillos vibradores, juguetes para hombres'
  },
  'bienestar-intimo': {
    title: 'Bienestar Íntimo | Cuidado Personal | Kuruba Sexshop',
    description: '🌸 Productos para tu bienestar: limpiadores íntimos, aceites de masaje, bolas chinas y más. Cuida tu salud sexual.',
    keywords: 'bienestar íntimo, cuidado personal, aceites masaje, bolas chinas, limpiadores íntimos'
  }
};

const seoData = categoryDescriptions[slug as string] || {
  title: `${category.label} | Kuruba Sexshop Colombia`,
  description: `Descubre nuestra selección de ${category.label.toLowerCase()}. Productos de calidad con envío discreto a toda Colombia. ¡Compra segura!`,
  keywords: `${category.label.toLowerCase()}, productos eróticos, sexshop colombia`
};
---

<BaseLayout 
  title={seoData.title}
  description={seoData.description}
  keywords={seoData.keywords}
>
  <main class="pt-24 pb-16 min-h-screen bg-white">
    <div class="container mx-auto px-4 md:px-8">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12 border-b border-neutral-200 pb-8">
        <div>
          <span class="text-rose-600 font-bold text-sm tracking-wider uppercase mb-2 block">{category.label}</span>
          <h1 class="text-3xl md:text-5xl font-bold text-neutral-900 mb-4 tracking-tight">
            {category.label}
          </h1>
          <p class="text-neutral-500 max-w-2xl text-lg leading-relaxed">
            {isOffersPage 
              ? 'Aprovecha nuestros mejores descuentos y promociones especiales'
              : `Descubre nuestra selección exclusiva de ${category.label.toLowerCase()}`
            }
          </p>
          <p class="text-sm text-neutral-400 mt-2">
            <span id="product-count">{mappedProducts.length}</span> {isOffersPage ? 'productos en oferta' : 'productos disponibles'}
          </p>
        </div>
        
        <button
          id="open-filters"
          class="group flex items-center justify-center gap-3 px-8 py-3 bg-neutral-900 text-white font-semibold rounded-full hover:bg-neutral-800 transition-all shadow-sm hover:shadow-md active:scale-95 whitespace-nowrap cursor-pointer"
        >
          <span class="mr-1">Filtros</span>
          <Icon name="filter" />
        </button>
      </div>

      {mappedProducts.length > 0 ? (
        <ProductGrid products={mappedProducts} />
      ) : (
        <div class="text-center py-16 text-gray-500">
          <p>{isOffersPage ? 'No hay productos en oferta en este momento' : 'No hay productos disponibles en esta categoría'}</p>
          <a href="/tienda" class="text-pink-600 hover:underline mt-4 inline-block">
            Ver todos los productos
          </a>
        </div>
      )}
    </div>
    
    <FilterPanel showCategoryFilter={false} />
  </main>
</BaseLayout>